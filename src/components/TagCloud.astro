---
interface Props {
  tags: Map<string, number>;
  activeTag?: string;
}

const { tags, activeTag } = Astro.props;
const sortedTags = [...tags.entries()].sort((a, b) => b[1] - a[1]);
---

<div class="flex flex-wrap gap-2">
  {sortedTags.map(([tag, count]) => {
    const isActive = activeTag === tag;
    return (
      <a
        href={`/tags/${tag}/`}
        class:list={[
          "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm transition-colors",
          isActive
            ? "bg-accent text-white"
            : "bg-bg-card text-text-secondary hover:bg-bg-card-hover hover:text-text-primary border border-border",
        ]}
      >
        <span>{tag}</span>
        <span class:list={[
          "text-xs",
          isActive ? "text-white/70" : "text-text-muted"
        ]}>
          {count}
        </span>
      </a>
    );
  })}
</div>
