---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/", label: "Dashboard", icon: "home" },
  { href: "/prompts/", label: "Prompts", icon: "music" },
  { href: "/templates/", label: "Templates", icon: "layout" },
  { href: "/tags/", label: "Tags", icon: "tag" },
];
---

<aside class="fixed top-0 left-0 w-64 h-screen bg-bg-secondary border-r border-border flex flex-col">
  <div class="p-6 border-b border-border">
    <a href="/" class="flex items-center gap-3 group">
      <span class="text-2xl">♪</span>
      <div>
        <h1 class="text-lg font-bold text-text-primary group-hover:text-accent transition-colors">
          Suno Prompts
        </h1>
        <p class="text-xs text-text-muted">Music Prompt Notes</p>
      </div>
    </a>
  </div>

  <nav class="flex-1 p-4 space-y-1">
    {navItems.map((item) => {
      const isActive = currentPath === item.href ||
        (item.href !== "/" && currentPath.startsWith(item.href));
      return (
        <a
          href={item.href}
          class:list={[
            "flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm font-medium transition-colors",
            isActive
              ? "bg-accent/15 text-accent"
              : "text-text-secondary hover:text-text-primary hover:bg-bg-card",
          ]}
        >
          <span class="w-5 text-center">
            {item.icon === "home" && "⌂"}
            {item.icon === "music" && "♫"}
            {item.icon === "layout" && "◫"}
            {item.icon === "tag" && "#"}
          </span>
          {item.label}
        </a>
      );
    })}
  </nav>

  <div class="p-4 border-t border-border">
    <p class="text-xs text-text-muted text-center">
      Prompt Notes v0.1
    </p>
  </div>
</aside>
