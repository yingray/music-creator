---
interface Props {
  slug: string;
  title: string;
  genre: string;
  mood: string;
  tags: string[];
  rating?: number;
  starred: boolean;
  suno_model: string;
  updated: Date;
}

const { slug, title, genre, mood, tags, rating, starred, suno_model, updated } = Astro.props;

const ratingStars = rating ? "★".repeat(rating) + "☆".repeat(5 - rating) : "";
---

<a
  href={`/prompts/${slug}/`}
  class="block bg-bg-card border border-border rounded-xl p-5 hover:bg-bg-card-hover hover:border-accent/30 transition-all group"
>
  <div class="flex items-start justify-between mb-3">
    <h3 class="text-base font-semibold text-text-primary group-hover:text-accent transition-colors">
      {starred && <span class="text-star mr-1">★</span>}
      {title}
    </h3>
    <span class="text-xs text-text-muted bg-bg-secondary px-2 py-0.5 rounded">
      {suno_model}
    </span>
  </div>

  <div class="flex items-center gap-2 mb-3 text-xs">
    <span class="bg-accent/15 text-accent px-2 py-0.5 rounded">{genre}</span>
    <span class="bg-bg-secondary text-text-secondary px-2 py-0.5 rounded">{mood}</span>
    {rating && (
      <span class="text-star ml-auto" title={`Rating: ${rating}/5`}>
        {ratingStars}
      </span>
    )}
  </div>

  <div class="flex flex-wrap gap-1.5">
    {tags.slice(0, 5).map((tag) => (
      <span class="text-xs text-text-muted bg-bg-primary px-2 py-0.5 rounded">
        {tag}
      </span>
    ))}
    {tags.length > 5 && (
      <span class="text-xs text-text-muted">+{tags.length - 5}</span>
    )}
  </div>

  <div class="mt-3 text-xs text-text-muted">
    Updated {updated.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
  </div>
</a>
