---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allTemplates = await getCollection("templates");
const sortedTemplates = allTemplates.sort(
  (a, b) => b.data.updated.getTime() - a.data.updated.getTime()
);
---

<BaseLayout title="Templates">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold mb-2">Prompt Templates</h1>
      <p class="text-text-secondary">Reusable templates to quickly generate new prompts.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {sortedTemplates.map((template) => (
        <a
          href={`/templates/${template.id}/`}
          class="block bg-bg-card border border-border rounded-xl p-5 hover:bg-bg-card-hover hover:border-accent/30 transition-all group"
        >
          <h3 class="text-base font-semibold text-text-primary group-hover:text-accent transition-colors mb-2">
            {template.data.title}
          </h3>
          <p class="text-sm text-text-secondary mb-3">{template.data.description}</p>
          <div class="flex flex-wrap gap-1.5 mb-3">
            {template.data.tags.map((tag) => (
              <span class="text-xs text-text-muted bg-bg-primary px-2 py-0.5 rounded">{tag}</span>
            ))}
          </div>
          <div class="text-xs text-text-muted font-mono bg-bg-primary rounded p-2 truncate">
            {template.data.prompt_template}
          </div>
        </a>
      ))}
    </div>

    {sortedTemplates.length === 0 && (
      <p class="text-text-muted text-center py-8">No templates yet. Create one in src/content/templates/.</p>
    )}
  </div>
</BaseLayout>
