---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PromptCard from "../../components/PromptCard.astro";
import { getCollection } from "astro:content";

const allPrompts = await getCollection("prompts");
const sortedPrompts = allPrompts.sort(
  (a, b) => b.data.updated.getTime() - a.data.updated.getTime()
);

const genres = [...new Set(allPrompts.map((p) => p.data.genre))].sort();
const moods = [...new Set(allPrompts.map((p) => p.data.mood))].sort();
const models = [...new Set(allPrompts.map((p) => p.data.suno_model))].sort();
---

<BaseLayout title="All Prompts">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold mb-2">Prompts</h1>
      <p class="text-text-secondary">{allPrompts.length} prompt notes in your collection.</p>
    </div>

    <!-- Filters -->
    <div class="flex flex-wrap gap-3" id="filters">
      <select
        class="bg-bg-card border border-border rounded-lg px-3 py-2 text-sm text-text-primary"
        data-filter="genre"
      >
        <option value="">All Genres</option>
        {genres.map((g) => <option value={g}>{g}</option>)}
      </select>

      <select
        class="bg-bg-card border border-border rounded-lg px-3 py-2 text-sm text-text-primary"
        data-filter="mood"
      >
        <option value="">All Moods</option>
        {moods.map((m) => <option value={m}>{m}</option>)}
      </select>

      <select
        class="bg-bg-card border border-border rounded-lg px-3 py-2 text-sm text-text-primary"
        data-filter="model"
      >
        <option value="">All Models</option>
        {models.map((m) => <option value={m}>{m}</option>)}
      </select>

      <select
        class="bg-bg-card border border-border rounded-lg px-3 py-2 text-sm text-text-primary"
        data-filter="rating"
      >
        <option value="">All Ratings</option>
        {[5, 4, 3, 2, 1].map((r) => (
          <option value={String(r)}>{"★".repeat(r)} & up</option>
        ))}
      </select>
    </div>

    <!-- Prompt Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="prompt-grid">
      {sortedPrompts.map((prompt) => (
        <div
          data-genre={prompt.data.genre}
          data-mood={prompt.data.mood}
          data-model={prompt.data.suno_model}
          data-rating={prompt.data.rating ?? 0}
        >
          <PromptCard
            slug={prompt.id}
            title={prompt.data.title}
            genre={prompt.data.genre}
            mood={prompt.data.mood}
            tags={prompt.data.tags}
            rating={prompt.data.rating}
            starred={prompt.data.starred}
            suno_model={prompt.data.suno_model}
            updated={prompt.data.updated}
          />
        </div>
      ))}
    </div>

    <p id="no-results" class="text-text-muted text-center py-8 hidden">
      No prompts match the current filters.
    </p>
  </div>
</BaseLayout>

<script>
  const filters = document.getElementById("filters")!;
  const grid = document.getElementById("prompt-grid")!;
  const noResults = document.getElementById("no-results")!;

  filters.addEventListener("change", () => {
    const genre = (filters.querySelector('[data-filter="genre"]') as HTMLSelectElement).value;
    const mood = (filters.querySelector('[data-filter="mood"]') as HTMLSelectElement).value;
    const model = (filters.querySelector('[data-filter="model"]') as HTMLSelectElement).value;
    const minRating = Number(
      (filters.querySelector('[data-filter="rating"]') as HTMLSelectElement).value || "0"
    );

    let visibleCount = 0;
    for (const card of grid.children) {
      const el = card as HTMLElement;
      const matchGenre = !genre || el.dataset.genre === genre;
      const matchMood = !mood || el.dataset.mood === mood;
      const matchModel = !model || el.dataset.model === model;
      const matchRating = Number(el.dataset.rating) >= minRating;
      const visible = matchGenre && matchMood && matchModel && matchRating;
      el.style.display = visible ? "" : "none";
      if (visible) visibleCount++;
    }

    noResults.classList.toggle("hidden", visibleCount > 0);
  });
</script>
