---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PromptCard from "../../components/PromptCard.astro";
import TagCloud from "../../components/TagCloud.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const allPrompts = await getCollection("prompts");
  const tags = new Set(allPrompts.flatMap((p) => p.data.tags));

  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      prompts: allPrompts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.updated.getTime() - a.data.updated.getTime()),
    },
  }));
}

const { tag, prompts } = Astro.props;

const allPrompts = await getCollection("prompts");
const tagCounts = new Map<string, number>();
for (const prompt of allPrompts) {
  for (const t of prompt.data.tags) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
---

<BaseLayout title={`Tag: ${tag}`}>
  <div class="space-y-6">
    <div>
      <a
        href="/tags/"
        class="text-sm text-text-muted hover:text-accent transition-colors mb-4 inline-block"
      >
        ← All Tags
      </a>
      <h1 class="text-2xl font-bold mb-2">
        <span class="text-accent">#</span>{tag}
      </h1>
      <p class="text-text-secondary">{prompts.length} prompt{prompts.length !== 1 ? "s" : ""} tagged.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {prompts.map((prompt) => (
        <PromptCard
          slug={prompt.id}
          title={prompt.data.title}
          genre={prompt.data.genre}
          mood={prompt.data.mood}
          tags={prompt.data.tags}
          rating={prompt.data.rating}
          starred={prompt.data.starred}
          suno_model={prompt.data.suno_model}
          metatags={prompt.data.metatags}
          updated={prompt.data.updated}
        />
      ))}
    </div>

    <div class="pt-4 border-t border-border">
      <h2 class="text-sm font-semibold text-text-muted uppercase tracking-wider mb-3">
        All Tags
      </h2>
      <TagCloud tags={tagCounts} activeTag={tag} />
    </div>
  </div>
</BaseLayout>
